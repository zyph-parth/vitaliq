# VitalIQ - Environment Variables
# Copy this to .env.local and fill in your values

# DATABASE
# Get a free PostgreSQL DB from: https://supabase.com or https://neon.tech
# Use a pooled/runtime URL here in production if your provider offers one.
DATABASE_URL="postgresql://user:password@host:5432/vitaliq"
# Use a direct or session-pooled URL for Prisma migrations on deploy.
DIRECT_URL="postgresql://user:password@host:5432/vitaliq"

# AUTH
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# GEMINI AI
# Get a free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
# Optional: override the model failover order used by /api/gemini
GEMINI_MODEL_PRIMARY="gemini-2.5-flash"
GEMINI_MODEL_FALLBACKS="gemini-2.5-flash-lite"

# NEXT PUBLIC (available on client)
# Keep Gemini calls server-side only for security
NEXT_PUBLIC_APP_URL="http://localhost:3000"
