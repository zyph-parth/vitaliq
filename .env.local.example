# VitalIQ — Environment Variables Template
# Copy this file to .env.local and fill in all values before running or deploying.
# NEVER commit .env.local to git. It is in .gitignore.

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String
# Use the "URI" format (postgresql://...) with ?pgbouncer=true for pooled connections
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?pgbouncer=true&connection_limit=1"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# REQUIRED: generate with: openssl rand -base64 32
# Without this, all sessions will be unsigned and insecure.
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_-base64_32"

# REQUIRED in production: must match your deployment URL exactly (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Primary model to use (first tried before fallbacks)
GEMINI_MODEL_PRIMARY="gemini-2.5-flash"

# Comma-separated fallback models (tried in order if primary fails/is rate-limited)
# GEMINI_MODEL_FALLBACKS="gemini-2.5-flash-lite"

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
# Required for the Gemini route's sliding-window rate limiter.
UPSTASH_REDIS_REST_URL="your_upstash_redis_rest_url"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token"

# ─── App URL (for server actions CORS) ───────────────────────────────────────
# Must match your deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ─── Optional: local dev overrides ─────────────────────────────────────────
# Uncomment for local development:
# NEXTAUTH_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
